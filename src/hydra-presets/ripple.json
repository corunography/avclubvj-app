{
  "name": "Ripple",
  "code": "src(o0)\n  .modulate(\n    osc(() => 8 + p1 * 15, () => 0.05 + p3 * 0.15),\n    () => 0.08 + p2 * 0.2 + a.fft[0] * 0.12\n  )\n  .modulate(\n    osc(() => 12 + p1 * 20, () => 0.08 + p3 * 0.2).rotate(Math.PI / 2),\n    () => 0.06 + p2 * 0.14 + a.fft[1] * 0.1\n  )\n  .scale(() => 0.996 + a.fft[0] * 0.012)\n  .hue(() => 0.003 * p3 * 2 + a.fft[2] * 0.02)\n  .saturate(() => 1.8 + p5 * 2.5)\n  .brightness(() => -0.007 + a.fft[0] * 0.006)\n  .out(o0)"
