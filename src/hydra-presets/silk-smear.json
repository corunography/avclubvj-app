{
  "name": "Silk Smear",
  "code": "src(o0)\n  .scale(() => 1.001 + a.fft[0] * 0.01 + p1 * 0.01)\n  .hue(() => time * 0.0015 * p3 * 3)\n  .out(o1)\n\nsrc(o0)\n  .scale(() => 1.001 + a.fft[0] * 0.012 + p1 * 0.008)\n  .rotate(() => a.fft[1] * 0.007 * p3 * 2)\n  .layer(\n    src(o1)\n      .color(() => 1.8 + p5 * 1.5 + a.fft[3], 0.1, 0.1)\n      .mask(noise(() => 1.2 + p1 * 5 + a.fft[0] * 3).thresh(() => 0.42 + a.fft[0] * 0.32))\n  )\n  .layer(\n    src(o1)\n      .color(0.1, () => 1.8 + p5 * 1.5 + a.fft[2], 0.1)\n      .mask(noise(() => 1.2 + p1 * 5 + a.fft[1] * 3, 0.5).thresh(() => 0.42 + a.fft[1] * 0.32))\n  )\n  .layer(\n    src(o1)\n      .color(0.1, 0.1, () => 1.8 + p5 * 1.5 + a.fft[0])\n      .mask(noise(() => 1.2 + p1 * 5 + a.fft[2] * 3, 1.0).thresh(() => 0.42 + a.fft[2] * 0.32))\n  )\n  .blend(src(o0), () => 0.78 + p4 * 0.19)\n  .out(o0)"
